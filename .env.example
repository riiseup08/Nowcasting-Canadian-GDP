# ── PostgreSQL / Supabase connection ────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# Get your connection string from the Supabase Dashboard → "Connect" button.
#
# Option A (recommended): a single connection string.
#   Uncomment DATABASE_URL below and paste the string. warehouse.py uses this
#   first if present, ignoring the DB_* variables.
#
# Option B: the individual components (DB_HOST / DB_PORT / ...).
#
# IMPORTANT — deploying to Streamlit Community Cloud:
#   Use the "Session pooler" (or "Transaction pooler") string, NOT the
#   "Direct connection" one. The direct host (db.<ref>.supabase.co) is
#   IPv6-only on the free tier and Streamlit Cloud cannot reach it. The
#   pooler is IPv4 and looks like:
#     postgresql://postgres.<ref>:password@aws-0-<region>.pooler.supabase.com:5432/postgres
#   Note the username becomes  postgres.<project-ref>.
#
# Used by: warehouse.py, transform.py, train_model.py, dashboard/app.py

# DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-xx-xx-xx.pooler.supabase.com:5432/postgres

DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# ── DeepSeek API key (for the Senior Economist AI agent) ─────────────────────
# Get your API key at: https://platform.deepseek.com/api_keys
# Used by: agent/graph.py, send_digest.py
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── SMTP email (for the monthly digest) ──────────────────────────────────────
# Used by: .github/workflows/monthly_update.yml (dawidd6/action-send-mail action)
# SMTP_USERNAME=monthe1994@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
# EMAIL_TO=monthe1994@gmail.com