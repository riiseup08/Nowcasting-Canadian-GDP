# ── PostgreSQL / Supabase connection ────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# Get your Supabase connection string from:
#   Supabase Dashboard → Project Settings → Database → Connection string (URI)
#
# For Supabase the connection string looks like:
#   postgresql://postgres.xxxxx:password@aws-0-xx-xx-xx.pooler.supabase.com:6543/postgres
#
# Used by: warehouse.py, transform.py, train_model.py, dashboard/app.py

DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# ── DeepSeek API key (for the Senior Economist AI agent) ─────────────────────
# Get your API key at: https://platform.deepseek.com/api_keys
# Used by: agent/graph.py
DEEPSEEK_API_KEY=your_deepseek_api_key_here