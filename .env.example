# PostgreSQL connection for the data warehouse
# Copy this file to .env and fill in your credentials
# Used by: warehouse.py, transform.py, train_model.py, dashboard/app.py

DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# DeepSeek API key for the Senior Economist conversational agent
# Get your API key at: https://platform.deepseek.com/api_keys
# Used by: agent/graph.py
DEEPSEEK_API_KEY=your_deepseek_api_key_here
